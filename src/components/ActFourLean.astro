---
// BRUTAL-EDIT VARIANT of ActFour, reworked as a left-aligned cost ledger
// (worked-document feel per DESIGN.md) so it no longer mirrors the centered
// Offer benefit boxes. Each row: animated equipment icon, the load + one line,
// and the replacement cost right-aligned like a price list.
const items = [
  { key: "rack", fig: "$30K–$80K", per: "per system", term: "Full rack refrigeration system", line: "Most stores run multiple racks, so the replacement exposure multiplies." },
  { key: "rtu", fig: "$10K–$45K", per: "per unit", term: "Rooftop HVAC unit", line: "Health-code closure risk when cooling fails during food-handling hours." },
  { key: "walkin", fig: "$10K–$15K", per: "per compressor", term: "Walk-in compressor", line: "Product loss from a single overnight failure runs $10K–$100K on its own." },
];
---

<section class="section afl" id="what-we-find" aria-labelledby="afl-title">
  <div class="container">
    <div class="afl__head reveal">
      <h2 class="afl__title" id="afl-title">What dirty power costs a supermarket.</h2>
      <p class="afl__lede lede">
        None of this shows up as a line item called waste, or in a standard
        energy audit, so it survives for years until we measure it at the panel.
      </p>
    </div>

    <ul class="afl__ledger">
      <li class="afl__head-row" aria-hidden="true">
        <span class="afl__h-load">The load</span>
        <span class="afl__h-cost">Replacement cost</span>
      </li>
      {items.map((it, i) => (
        <li class="afl__row reveal" style={`--i: ${i}`}>
          <span class="afl__ico" aria-hidden="true">
            {it.key === "rack" && (
              <svg viewBox="0 0 48 48" fill="none">
                <rect class="afl__i-stroke" x="8" y="22" width="32" height="18" rx="2" />
                <rect class="afl__i-cab afl__i-stroke" x="12" y="12" width="7" height="10" rx="1.5" />
                <rect class="afl__i-cab afl__i-stroke" x="20.5" y="12" width="7" height="10" rx="1.5" />
                <rect class="afl__i-cab afl__i-stroke" x="29" y="12" width="7" height="10" rx="1.5" />
                <line class="afl__i-stroke" x1="8" y1="31" x2="40" y2="31" opacity="0.5" />
                <g class="afl__spin">
                  <circle class="afl__i-hub" cx="24" cy="35.5" r="1.8" />
                  <path class="afl__i-vane" d="M24 35.5 q6 -3 8 1.5" />
                  <path class="afl__i-vane" d="M24 35.5 q-6 3 -8 -1.5" />
                  <path class="afl__i-vane" d="M24 35.5 q3 6 -1.5 8" />
                  <path class="afl__i-vane" d="M24 35.5 q-3 -6 1.5 -8" />
                </g>
              </svg>
            )}
            {it.key === "rtu" && (
              <svg viewBox="0 0 48 48" fill="none">
                <rect class="afl__i-stroke" x="7" y="20" width="34" height="20" rx="2" />
                <line class="afl__i-stroke" x1="11" y1="40" x2="11" y2="43" />
                <line class="afl__i-stroke" x1="37" y1="40" x2="37" y2="43" />
                <line class="afl__i-stroke" x1="12" y1="26" x2="20" y2="26" opacity="0.6" />
                <line class="afl__i-stroke" x1="12" y1="30" x2="20" y2="30" opacity="0.6" />
                <line class="afl__i-stroke" x1="12" y1="34" x2="20" y2="34" opacity="0.6" />
                <g class="afl__spin">
                  <circle class="afl__i-hub" cx="31" cy="30" r="2" />
                  <ellipse class="afl__i-blade" cx="31" cy="24.5" rx="2.4" ry="5" />
                  <ellipse class="afl__i-blade" cx="36.5" cy="30" rx="5" ry="2.4" />
                  <ellipse class="afl__i-blade" cx="31" cy="35.5" rx="2.4" ry="5" />
                  <ellipse class="afl__i-blade" cx="25.5" cy="30" rx="5" ry="2.4" />
                </g>
              </svg>
            )}
            {it.key === "walkin" && (
              <svg viewBox="0 0 48 48" fill="none">
                <rect class="afl__i-stroke" x="8" y="16" width="32" height="22" rx="2" />
                <circle class="afl__i-stroke" cx="17" cy="27" r="6" />
                <line class="afl__i-stroke" x1="17" y1="23" x2="17" y2="31" opacity="0.55" />
                <g class="afl__spin">
                  <circle class="afl__i-hub" cx="31" cy="27" r="2" />
                  <ellipse class="afl__i-blade" cx="31" cy="22" rx="2.2" ry="4.5" />
                  <ellipse class="afl__i-blade" cx="36" cy="27" rx="4.5" ry="2.2" />
                  <ellipse class="afl__i-blade" cx="31" cy="32" rx="2.2" ry="4.5" />
                  <ellipse class="afl__i-blade" cx="26" cy="27" rx="4.5" ry="2.2" />
                </g>
              </svg>
            )}
          </span>
          <span class="afl__detail">
            <span class="afl__term">{it.term}</span>
            <span class="afl__line">{it.line}</span>
          </span>
          <span class="afl__cost">
            <span class="afl__fig">{it.fig}</span>
            <span class="afl__per">{it.per}</span>
          </span>
        </li>
      ))}
    </ul>
  </div>
</section>

<style>
  .afl {
    border-top: 1px solid var(--line);
    background:
      radial-gradient(ellipse 50% 45% at 8% 100%, rgba(199, 168, 107, 0.04), transparent 70%),
      var(--bg);
  }
  .afl__head { max-width: 54rem; }
  .afl__title { font-size: var(--step-3); max-width: 20ch; }
  .afl__lede { margin-top: var(--space-m); max-width: 56ch; }

  .afl__ledger {
    list-style: none;
    margin: var(--space-xl) 0 0;
    padding: 0;
  }
  .afl__head-row {
    display: flex;
    justify-content: space-between;
    padding-bottom: var(--space-2xs);
    border-bottom: 1px solid var(--line-strong);
    font-family: var(--font-mono);
    font-size: 0.68rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--muted);
  }
  .afl__row {
    display: grid;
    grid-template-columns: 44px minmax(0, 1fr) auto;
    align-items: center;
    column-gap: clamp(1rem, 3vw, 2rem);
    padding: clamp(1.1rem, 3vw, 1.6rem) 0;
    border-bottom: 1px solid var(--line);
  }

  .afl__ico svg { width: 40px; height: 40px; }
  .afl__i-stroke {
    stroke: var(--gold-text); stroke-width: 1.6; fill: none;
    stroke-linecap: round; stroke-linejoin: round;
  }
  .afl__i-cab { fill: rgba(216, 190, 134, 0.16); }
  .afl__i-hub { fill: var(--gold-text); }
  .afl__i-blade { fill: rgba(216, 190, 134, 0.6); }
  .afl__i-vane { stroke: var(--gold-text); stroke-width: 1.6; fill: none; stroke-linecap: round; }

  .afl__detail { display: flex; flex-direction: column; gap: 0.25rem; }
  .afl__term { font-size: var(--step-1); color: var(--ink); letter-spacing: -0.01em; }
  .afl__line { font-size: var(--step--1); line-height: 1.5; color: var(--body); max-width: 52ch; }

  .afl__cost {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    text-align: right;
    white-space: nowrap;
  }
  .afl__fig {
    font-family: var(--font-serif);
    font-size: clamp(1.5rem, 2.6vw, 2.1rem);
    line-height: 1;
    color: var(--gold-text);
    letter-spacing: -0.02em;
    font-variant-numeric: tabular-nums;
  }
  .afl__per {
    margin-top: 0.3rem;
    font-family: var(--font-mono);
    font-size: 0.66rem;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: var(--muted);
  }

  @media (prefers-reduced-motion: no-preference) {
    .afl__spin { transform-box: fill-box; transform-origin: center; animation: aflSpin 3.2s linear infinite; }
    @keyframes aflSpin { to { transform: rotate(360deg); } }
    /* the three rows' fans/flywheels spin at slightly different rates */
    .afl__row:nth-child(3) .afl__spin { animation-duration: 2.6s; }
    .afl__row:nth-child(4) .afl__spin { animation-duration: 3.8s; }
  }

  @media (max-width: 40rem) {
    .afl__row {
      grid-template-columns: 40px 1fr;
      grid-template-areas: "ico detail" "ico cost";
      row-gap: 0.4rem;
    }
    .afl__ico { grid-area: ico; align-self: start; }
    .afl__detail { grid-area: detail; }
    .afl__cost { grid-area: cost; align-items: flex-start; text-align: left; }
    .afl__head-row { display: none; }
  }
</style>
