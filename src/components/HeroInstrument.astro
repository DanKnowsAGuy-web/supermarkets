---
// HYBRID-THEME hero: a recolor of Hero.astro into the unified instrument
// palette — graphite ground, red distortion (kept), brass->teal for the clean/
// verified signals. Forked so the original forest/brass hero stays intact on
// the other pages. Structure + JS identical to Hero.astro.
import CtaPair from "./CtaPair.astro";
import Disc from "./Disc.astro";
function grid(x0, y0, cols, rows, gapX, gapY, w, h, lit) {
  const cells = [];
  for (let r = 0; r < rows; r++) {
    for (let c = 0; c < cols; c++) {
      cells.push({ x: x0 + c * gapX, y: y0 + r * gapY, w, h, lit: lit.has(r + "-" + c) });
    }
  }
  return cells;
}
const tower = grid(448, 150, 5, 9, 40, 42, 26, 28,
  new Set(["1-3", "2-0", "3-2", "4-4", "5-1", "6-3", "7-0", "8-2"]));
const wingL = grid(322, 262, 2, 6, 46, 48, 28, 30, new Set(["0-1", "3-0", "5-1"]));
const wingR = grid(676, 262, 2, 6, 46, 48, 28, 30, new Set(["1-0", "2-1", "4-0"]));

function wire(x1, y1, x2, y2, amp = 2.4, wl = 17) {
  const dx = x2 - x1, dy = y2 - y1;
  const len = Math.hypot(dx, dy) || 1;
  const ux = dx / len, uy = dy / len;
  const px = -uy, py = ux;
  const steps = Math.max(12, Math.round(len / 3));
  let d = "";
  for (let i = 0; i <= steps; i++) {
    const t = i / steps;
    const off = amp * Math.sin((t * len) / wl * Math.PI * 2);
    const x = x1 + dx * t + px * off;
    const y = y1 + dy * t + py * off;
    d += (i === 0 ? "M" : "L") + x.toFixed(1) + " " + y.toFixed(1);
  }
  return d;
}
const mains = [
  [540, 100, 540, 542, 2.2, 15],
  [470, 128, 470, 540, 2.4, 17],
  [610, 128, 610, 540, 2.4, 17],
  [360, 244, 360, 540, 2.4, 17],
  [720, 244, 720, 540, 2.4, 17],
];
const runs = [
  [470, 162, 610, 162], [470, 204, 610, 204], [360, 288, 720, 288],
  [320, 372, 760, 372], [360, 456, 720, 456], [470, 498, 610, 498],
  [300, 312, 430, 312], [650, 312, 780, 312],
  [300, 456, 430, 456], [650, 456, 780, 456],
];
const branches = [
  [540, 128, 540, 102, 3.2, 12],
  [540, 288, 600, 330, 3.4, 12],
  [470, 456, 366, 452, 3.4, 12],
  [540, 498, 500, 520, 3.4, 12],
  [610, 498, 720, 512, 3.4, 12],
  [540, 372, 470, 372, 3.4, 12],
  [360, 312, 360, 324, 3.4, 10],
];
---

