---
// HYBRID-THEME hero: a recolor of Hero.astro into the unified instrument
// palette — graphite ground, red distortion (kept), brass->teal for the clean/
// verified signals. Forked so the original forest/brass hero stays intact on
// the other pages. Structure + JS identical to Hero.astro.
import CtaPair from "./CtaPair.astro";
import Disc from "./Disc.astro";
function wire(x1, y1, x2, y2, amp = 2.4, wl = 17) {
  const dx = x2 - x1, dy = y2 - y1;
  const len = Math.hypot(dx, dy) || 1;
  const ux = dx / len, uy = dy / len;
  const px = -uy, py = ux;
  const steps = Math.max(12, Math.round(len / 3));
  let d = "";
  for (let i = 0; i <= steps; i++) {
    const t = i / steps;
    const off = amp * Math.sin((t * len) / wl * Math.PI * 2);
    const x = x1 + dx * t + px * off;
    const y = y1 + dy * t + py * off;
    d += (i === 0 ? "M" : "L") + x.toFixed(1) + " " + y.toFixed(1);
  }
  return d;
}
// Bird's-eye wiring: a back-of-house distribution bus feeds the machine room,
// then risers drop south into the sales-floor refrigeration and the right-wall
// case feed. Drawn as wavy "dirty current" the scanner reveals under the roof.
const mains = [
  [460, 330, 884, 330, 2.4, 17],
  [560, 355, 560, 468, 2.4, 17],
  [900, 360, 900, 468, 2.2, 15],
];
const runs = [
  [535, 330, 535, 305], [645, 330, 645, 312], [790, 330, 790, 320],
  [560, 415, 575, 415], [510, 392, 510, 380],
  [560, 440, 815, 492], [884, 330, 900, 360], [620, 470, 760, 492],
];
const branches = [
  [535, 305, 560, 330, 3.2, 12],
  [645, 312, 645, 330, 3.4, 12],
  [575, 415, 560, 415, 3.4, 12],
  [510, 380, 510, 392, 3.4, 12],
  [900, 420, 900, 400, 3.4, 12],
  [815, 500, 815, 492, 3.4, 12],
];
---

