---
// HYBRID-THEME hero: a recolor of Hero.astro into the unified instrument
// palette — graphite ground, red distortion (kept), brass->teal for the clean/
// verified signals. Forked so the original forest/brass hero stays intact on
// the other pages. Structure + JS identical to Hero.astro.
import CtaPair from "./CtaPair.astro";
import Disc from "./Disc.astro";
function wire(x1, y1, x2, y2, amp = 2.4, wl = 17) {
  const dx = x2 - x1, dy = y2 - y1;
  const len = Math.hypot(dx, dy) || 1;
  const ux = dx / len, uy = dy / len;
  const px = -uy, py = ux;
  const steps = Math.max(12, Math.round(len / 3));
  let d = "";
  for (let i = 0; i <= steps; i++) {
    const t = i / steps;
    const off = amp * Math.sin((t * len) / wl * Math.PI * 2);
    const x = x1 + dx * t + px * off;
    const y = y1 + dy * t + py * off;
    d += (i === 0 ? "M" : "L") + x.toFixed(1) + " " + y.toFixed(1);
  }
  return d;
}
// Tall-store wiring: a service riser climbs the right wall, with tier mains at
// the mezzanine and floor feeding the roof units (top), the mid-level HVAC and
// switchgear, and the floor-level refrigeration. Wavy = the dirty current.
const mains = [
  [760, 540, 760, 130, 2.2, 15],
  [340, 360, 760, 360, 2.4, 17],
  [340, 500, 760, 500, 2.4, 17],
];
const runs = [
  [760, 150, 650, 150], [650, 360, 650, 166],
  [550, 360, 550, 270], [700, 360, 700, 305], [340, 360, 340, 320],
  [560, 500, 560, 480], [695, 500, 695, 470], [445, 500, 445, 490],
];
const branches = [
  [650, 150, 672, 170, 3.2, 12],
  [700, 305, 700, 330, 3.4, 12],
  [550, 270, 540, 290, 3.4, 12],
  [340, 320, 360, 340, 3.4, 12],
  [560, 480, 560, 500, 3.4, 12],
  [695, 470, 695, 500, 3.4, 12],
];
