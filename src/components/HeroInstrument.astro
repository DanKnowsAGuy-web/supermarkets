---
// HYBRID-THEME hero: a recolor of Hero.astro into the unified instrument
// palette — graphite ground, red distortion (kept), brass->teal for the clean/
// verified signals. Forked so the original forest/brass hero stays intact on
// the other pages. Structure + JS identical to Hero.astro.
import CtaPair from "./CtaPair.astro";
import Disc from "./Disc.astro";
function wire(x1, y1, x2, y2, amp = 2.4, wl = 17) {
  const dx = x2 - x1, dy = y2 - y1;
  const len = Math.hypot(dx, dy) || 1;
  const ux = dx / len, uy = dy / len;
  const px = -uy, py = ux;
  const steps = Math.max(12, Math.round(len / 3));
  let d = "";
  for (let i = 0; i <= steps; i++) {
    const t = i / steps;
    const off = amp * Math.sin((t * len) / wl * Math.PI * 2);
    const x = x1 + dx * t + px * off;
    const y = y1 + dy * t + py * off;
    d += (i === 0 ? "M" : "L") + x.toFixed(1) + " " + y.toFixed(1);
  }
  return d;
}
// Wiring for the big-box store: a service riser up the right wall, a ceiling
// main spanning the roof line that feeds the rooftop condensers, and a floor
// main running the length of the refrigerated case lineup.
const mains = [
  [752, 548, 752, 372, 2.2, 15],
  [300, 372, 762, 372, 2.4, 17],
  [300, 520, 668, 520, 2.4, 17],
];
const runs = [
  [410, 372, 410, 344], [520, 372, 520, 356], [620, 372, 620, 352],
  [720, 372, 720, 446], [300, 372, 300, 520],
  [430, 520, 430, 500], [520, 520, 520, 500], [600, 520, 600, 500],
  [360, 466, 320, 466], [360, 486, 312, 486],
];
const branches = [
  [752, 470, 724, 466, 3.2, 12],
  [752, 512, 740, 514, 3.4, 12],
  [410, 500, 410, 524, 3.4, 12],
  [300, 460, 330, 460, 3.4, 12],
  [580, 500, 580, 520, 3.4, 12],
  [648, 500, 648, 522, 3.4, 12],
  [520, 356, 520, 372, 3.4, 10],
];
---

