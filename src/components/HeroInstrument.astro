</section>

<script is:inline>
  (() => {
    const hero = document.querySelector(".hero");
    const scene = hero && hero.querySelector(".hero__scene");
    if (!hero || !scene) return;
    const fine = matchMedia("(hover: hover) and (pointer: fine)").matches;
    const reduce = matchMedia("(prefers-reduced-motion: reduce)").matches;
    const devs = Array.from(scene.querySelectorAll(".dev"));
    const NEAR = 135;

    const showNow = () => {};
    const setPos = (x, y) => {
      scene.style.setProperty("--mx", x + "px");
      scene.style.setProperty("--my", y + "px");
      const b = scene.getBoundingClientRect();
      if (b.width && b.height) {
        scene.style.setProperty("--pcx", (x / b.width - 0.5).toFixed(3));
        scene.style.setProperty("--pcy", (y / b.height - 0.5).toFixed(3));
      }
    };
    const markNear = (x, y) => {
      const box = scene.getBoundingClientRect();
      for (const d of devs) {
        const m = d.querySelector(".dev__glow") || d;
        const b = m.getBoundingClientRect();
        const hx = b.left + b.width / 2 - box.left;
        const hy = b.top + b.height / 2 - box.top;
        d.classList.toggle("is-near", Math.hypot(hx - x, hy - y) < NEAR);
      }
    };
    const centerOf = (d) => {
      const m = d.querySelector(".dev__glow") || d;
      const b = m.getBoundingClientRect();
      const box = scene.getBoundingClientRect();
      return { x: b.left + b.width / 2 - box.left, y: b.top + b.height / 2 - box.top };
    };
    const ease = (t) => (t < 0.5 ? 4 * t * t * t : 1 - Math.pow(-2 * t + 2, 3) / 2);

    // reduced motion: reveal the annotated blueprint, all waste counted
    if (reduce) {
      hero.classList.add("is-revealed");
      return;
    }

    // fine pointer: smooth lens follow + a one-time self-demo on load
    if (fine) {
      let tx = 0, ty = 0, lx = 0, ly = 0, raf = 0, primed = false, demo = true;
      function render() {
        lx += (tx - lx) * 0.16;
        ly += (ty - ly) * 0.16;
        setPos(lx, ly); markNear(lx, ly);
        if (Math.abs(tx - lx) > 0.5 || Math.abs(ty - ly) > 0.5) raf = requestAnimationFrame(render); else raf = 0;
      }
      hero.addEventListener("pointermove", (e) => {
        demo = false;
        const box = scene.getBoundingClientRect();
        tx = e.clientX - box.left; ty = e.clientY - box.top;
        if (!primed) { lx = tx; ly = ty; primed = true; }
        hero.classList.add("is-live");
        if (!raf) raf = requestAnimationFrame(render);
      }, { passive: true });
      hero.addEventListener("pointerleave", () => {
        hero.classList.remove("is-live");
        devs.forEach((d) => d.classList.remove("is-near"));
        showNow(null);
      });

      // self-demo: sweep across three trouble spots, then hand control over
      const demoPts = ["condenser", "rack", "switch"]
        .map((n) => scene.querySelector('.dev[data-dev="' + n + '"]')).filter(Boolean);
      if (demoPts.length) {
        let seg = 0, segStart = 0, phase = "hold", dstart = 0;
        const TRAVEL = 1150, HOLD = 750;
        hero.classList.add("is-live");
        const demoStep = (ts) => {
          if (!demo) { hero.classList.remove("is-live"); devs.forEach((d) => d.classList.remove("is-near")); return; }
          const pts = demoPts.map(centerOf);
          if (!dstart) { dstart = ts; segStart = ts; setPos(pts[0].x, pts[0].y); markNear(pts[0].x, pts[0].y); }
          if (phase === "travel") {
            const cur = pts[seg], nxt = pts[Math.min(seg + 1, pts.length - 1)];
            const t = Math.min(1, (ts - segStart) / TRAVEL), e = ease(t);
            const x = cur.x + (nxt.x - cur.x) * e, y = cur.y + (nxt.y - cur.y) * e;
            setPos(x, y); markNear(x, y);
            if (t >= 1) { seg++; phase = "hold"; segStart = ts; }
          } else {
            setPos(pts[seg].x, pts[seg].y); markNear(pts[seg].x, pts[seg].y);
            if (ts - segStart >= HOLD) {
              if (seg >= pts.length - 1) { demo = false; hero.classList.remove("is-live"); devs.forEach((d) => d.classList.remove("is-near")); showNow(null); return; }
              phase = "travel"; segStart = ts;
            }
          }
          requestAnimationFrame(demoStep);
        };
        requestAnimationFrame(demoStep);
      }
      return;
    }

    // touch / coarse: auto-tour every trouble spot on a loop
    const order = ["condenser", "rack", "cases", "walkin", "antisweat", "deli", "switch"]
      .map((n) => scene.querySelector('.dev[data-dev="' + n + '"]')).filter(Boolean);
    if (!order.length) return;
    const TRAVEL = 1700, HOLD = 1300;
    let oi = 0, phase = "hold", tstart = 0, from = null, to = null, started = false;
    hero.classList.add("is-auto", "is-live");
    function tour(ts) {
      if (!started) { to = centerOf(order[0]); from = { x: to.x, y: to.y }; setPos(to.x, to.y); markNear(to.x, to.y); tstart = ts; started = true; }
      if (phase === "travel") {
        const t = Math.min(1, (ts - tstart) / TRAVEL), e = ease(t);
        setPos(from.x + (to.x - from.x) * e, from.y + (to.y - from.y) * e);
        markNear(from.x + (to.x - from.x) * e, from.y + (to.y - from.y) * e);
        if (t >= 1) { phase = "hold"; tstart = ts; }
      } else {
        setPos(to.x, to.y); markNear(to.x, to.y);
        if (ts - tstart >= HOLD) { oi = (oi + 1) % order.length; from = { x: to.x, y: to.y }; to = centerOf(order[oi]); phase = "travel"; tstart = ts; }
      }
      requestAnimationFrame(tour);
    }
    requestAnimationFrame(tour);
  })();
</script>

