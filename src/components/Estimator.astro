---
// Native savings estimator, matched to the original _saveenergy calculator's
// HOTEL profile: harmoRate 0.08, hvacShare 0.45, cooling 15-55% of the cooling
// pool (pool = hvacShare x state cooling split), demand 0.05 x 0.40 (demand
// reduction x demand share), outdoor lighting hotel 4-9% (off-grid mult 1.0),
// rate negotiation 2.5-6% in deregulated states. Heating is left UNMODELED by
// default (an upside, never in the conservative floor), exactly as the
// original. Portfolio low x floor to high x ceiling; escalation via the annuity
// factor (ESC tiers/rates and the state cooling table identical to the original).
import CtaPair from "./CtaPair.astro";
import Disc from "./Disc.astro";
const STATE_COOL: Record<string, number> = {
  Alabama: 65, Alaska: 22, Arizona: 80, Arkansas: 65, California: 50,
  Colorado: 35, Connecticut: 35, Delaware: 50, "District of Columbia": 50,
  Florida: 80, Georgia: 65, Hawaii: 80, Idaho: 22, Illinois: 35, Indiana: 35,
  Iowa: 35, Kansas: 50, Kentucky: 50, Louisiana: 80, Maine: 22, Maryland: 50,
  Massachusetts: 35, Michigan: 22, Minnesota: 22, Mississippi: 65,
  Missouri: 50, Montana: 22, Nebraska: 35, Nevada: 65, "New Hampshire": 22,
  "New Jersey": 35, "New Mexico": 65, "New York": 35, "North Carolina": 65,
  "North Dakota": 22, Ohio: 35, Oklahoma: 65, Oregon: 50, Pennsylvania: 35,
  "Puerto Rico": 80, "Rhode Island": 35, "South Carolina": 65,
  "South Dakota": 22, Tennessee: 65, Texas: 80, Utah: 35, Vermont: 22,
  Virginia: 50, Washington: 50, "West Virginia": 50, Wisconsin: 22, Wyoming: 22,
};
const ESC_TIER: Record<string, number> = {
  California: 1, Hawaii: 1, Massachusetts: 1, "New York": 1, "New Jersey": 1,
  Connecticut: 1, Maryland: 2, "District of Columbia": 2, Illinois: 2,
  Pennsylvania: 2, Texas: 2, Virginia: 2, "Rhode Island": 2,
  "New Hampshire": 2, Maine: 2, Delaware: 2, Vermont: 2, Washington: 4,
  Idaho: 4, Montana: 4, "North Dakota": 4, "South Dakota": 4, Nebraska: 4,
  Wyoming: 4, "Puerto Rico": 5,
};
const BANDS: Record<number, { range: string; rate: number }> = {
  1: { range: "4–6%", rate: 0.045 },
  2: { range: "3–4%", rate: 0.035 },
  3: { range: "2–3%", rate: 0.025 },
  4: { range: "1–2%", rate: 0.018 },
  5: { range: "volatile", rate: 0.025 },
};
const DEREG = [
  "Connecticut", "Delaware", "Illinois", "Maine", "Maryland", "Massachusetts",
  "Michigan", "New Hampshire", "New Jersey", "New York", "Ohio",
  "Pennsylvania", "Rhode Island", "Texas", "District of Columbia",
];
// Utility-program coverage cap, "up to X% of project cost". Default is 50%;
// these states have a higher published cap. Drives the clarifier box under the
// state picker (step 4).
const COVERAGE: Record<string, number> = {
  Delaware: 85, Idaho: 70, Maryland: 85, Massachusetts: 75, Nevada: 90,
  "New Jersey": 60, "North Carolina": 75, Washington: 70, Wyoming: 70,
};
const states = Object.keys(STATE_COOL).map((name) => {
  const tier = ESC_TIER[name] || 3;
  return {
    name, cool: STATE_COOL[name],
    rate: BANDS[tier].rate, range: BANDS[tier].range,
    dereg: DEREG.includes(name) ? 1 : 0,
    cover: COVERAGE[name] || 50,
  };
});
const counts = [
  { lo: 1, hi: 1, label: "Just one", short: "1 property" },
  { lo: 2, hi: 4, label: "2 to 4", short: "2 to 4 properties" },
  { lo: 5, hi: 9, label: "5 to 9", short: "5 to 9 properties" },
  { lo: 10, hi: 19, label: "10 to 19", short: "10 to 19 properties" },
  { lo: 20, hi: 20, label: "20+", short: "20+ properties" },
];
// Monthly electricity spend, per supermarket. Pick a broad band, then dial it in;
// each narrow option carries a representative monthly midpoint that drives the
// model (annualized x12). Floor "Under $12k/mo", ceiling "Over $170k/mo".
const spendBands = [
  { key: "u12", label: "Under $12k", narrows: [
    { label: "Under $4k", mid: 3000 }, { label: "$4k–8k", mid: 6000 }, { label: "$8k–12k", mid: 10000 } ] },
  { key: "12-40", label: "$12k–40k", narrows: [
    { label: "$12k–20k", mid: 16000 }, { label: "$20k–30k", mid: 25000 }, { label: "$30k–40k", mid: 35000 } ] },
  { key: "40-80", label: "$40k–80k", narrows: [
    { label: "$40k–55k", mid: 47000 }, { label: "$55k–70k", mid: 62000 }, { label: "$70k–80k", mid: 75000 } ] },
  { key: "80-170", label: "$80k–170k", narrows: [
    { label: "$80k–110k", mid: 95000 }, { label: "$110k–140k", mid: 125000 }, { label: "$140k–170k", mid: 155000 } ] },
  { key: "o170", label: "Over $170k", narrows: [
    { label: "$170k–300k", mid: 210000 }, { label: "$300k–500k", mid: 380000 }, { label: "$500k+", mid: 600000 } ] },
];
---

<section class="section est" id="calculator" aria-labelledby="est-title">
  <div class="container">
    <div class="est__head reveal">
      <p class="est__eyebrow">
        <span class="est__eyebrow-dot" aria-hidden="true"></span>
        Interactive calculator · about 30 seconds
      </p>
      <h2 class="est__title reveal" id="est-title" data-words>Now run your own number.</h2>
      <p class="est__lede lede">
        Your spend, your state, your portfolio. This is a conservative model,
        not a quote. During the pilot we measure the real figure at your own
        meter, and the diagnosis is on us.
      </p>
    </div>

    <div class="est__flow est__flow--panel instrument-frame reveal" id="est-flow" style="--i: 1">
      <p class="est__cue" id="est-cue" aria-hidden="true">
        Tap an option to begin
        <svg viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M12 5v14M5 12l7 7 7-7" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" /></svg>
      </p>
      <!-- Step 1: monthly spend, broad band -->
      <fieldset class="est__step" id="est-step-spend">
        <legend class="est__legend"><span class="est__step-n">1</span>Your monthly electricity spend, per supermarket</legend>
        <div class="est__chips" role="radiogroup">
          {
            spendBands.map((b) => (
              <label class="est__chip est__chip--band">
                <input type="radio" name="est-band" value={b.key} />
                <span>{b.label}/mo</span>
              </label>
            ))
          }
        </div>
      </fieldset>

      <!-- Step 2: dial it in (the chosen band's narrow chips show) -->
      <fieldset class="est__step" id="est-step-narrow" hidden aria-hidden="true">
        <legend class="est__legend"><span class="est__step-n">2</span>Dial it in</legend>
        {
          spendBands.map((b) => (
            <div class="est__narrow-group" data-band={b.key} hidden>
              <div class="est__chips" role="radiogroup">
                {b.narrows.map((n) => (
                  <label class="est__chip">
                    <input type="radio" name="est-narrow" value={n.mid} data-label={n.label} />
                    <span>{n.label}/mo</span>
                  </label>
                ))}
              </div>
            </div>
          ))
        }
      </fieldset>

      <!-- Step 3: portfolio -->
      <fieldset class="est__step" id="est-step-count" hidden aria-hidden="true">
        <legend class="est__legend"><span class="est__step-n">3</span>How many supermarkets like this do you operate?</legend>
        <div class="est__chips" role="radiogroup">
          {
            counts.map((c) => (
              <label class="est__chip">
                <input type="radio" name="est-count" value={`${c.lo}-${c.hi}`} data-short={c.short} />
                <span>{c.label}</span>
              </label>
            ))
          }
        </div>
      </fieldset>

      <!-- Step 4: primary state -->
      <fieldset class="est__step" id="est-step-state" hidden aria-hidden="true">
        <legend class="est__legend"><span class="est__step-n">4</span>Primary state you operate in</legend>
        <div class="est__sel">
          <select id="est-state">
            <option value="" disabled selected>Choose your state</option>
            {
              states.map((s) => (
                <option value={s.name} data-cool={s.cool} data-rate={s.rate} data-range={s.range} data-dereg={s.dereg} data-cover={s.cover}>
                  {s.name}
                </option>
              ))
            }
          </select>
        </div>
        <p class="est__cover" id="est-cover" hidden aria-live="polite"></p>
      </fieldset>

      <!-- Step 5: square footage + 179D deduction (stays here, not in results) -->
      <fieldset class="est__step" id="est-step-sqft" hidden aria-hidden="true">
        <legend class="est__legend"><span class="est__step-n">5</span>Building square footage <span class="est__legend-note">(prefilled estimate; drag to your real number)</span></legend>
        <div class="est__sqft">
          <span class="est__sqft-cur" id="est-sqft-cur">&nbsp;</span>
          <input type="range" class="est__rng" id="est-sqft-slider" min="0" max="100" step="1" value="50" aria-label="Building square footage" />
          <div class="est__sqft-ends" aria-hidden="true"><span id="est-sqft-min"></span><span id="est-sqft-max"></span></div>
          <div class="est__ded">
            <span class="est__ded-label">Section 179D deduction, one-time<Disc to="tax" /></span>
            <span class="est__ded-val" id="est-ded">&nbsp;</span>
            <span class="est__ded-note" id="est-ded-tax"></span>
          </div>
        </div>
      </fieldset>
    </div>

    <div class="est__results" id="est-results" hidden aria-live="polite">
      <div class="est__report-head">
        <span class="est__report-title">Savings model</span>
        <span class="est__report-meta" id="est-report-meta"></span>
      </div>
      <p class="est__captured" id="est-captured" aria-hidden="true">
        <span class="est__captured-dot" aria-hidden="true"></span>Reading captured · modeled from your inputs
      </p>
      <div class="est__grid">
        <figure class="est__measured">
          <div class="est__dial">
            <svg viewBox="0 0 200 124" role="img" aria-label="Savings gauge for your estimated annual savings range, per property.">
              <path class="est__dial-track" d="M18 104 A82 82 0 0 1 182 104"></path>
              <path class="est__dial-band" id="est-band" d="M18 104 A82 82 0 0 1 18 104"></path>
              <g class="est__dial-tick" id="est-tick-lo"><line x1="100" y1="104" x2="100" y2="34"></line></g>
              <g class="est__dial-tick" id="est-tick-hi"><line x1="100" y1="104" x2="100" y2="34"></line></g>
              <circle class="est__dial-hub" cx="100" cy="104" r="6"></circle>
            </svg>
            <div class="est__dial-cap">
              <span class="est__dial-label">Annual savings, per property<Disc to="results" /></span>
              <span class="est__dial-val" id="est-newbill">&nbsp;</span>
              <span class="est__dial-sub" id="est-range"></span>
            </div>
          </div>
        </figure>

        <div class="est__accum">
          <span class="est__accum-head" id="est-portfolio-label"></span>
          <div class="est__proj">
            <span class="est__big-label">Unclaimed over five years</span>
            <span class="est__big-val" id="est-proj5"></span>
          </div>
          <div class="est__proj">
            <span class="est__big-label">Over ten years</span>
            <span class="est__big-val" id="est-proj10"></span>
          </div>
          <p class="est__proj-note" id="est-proj-note"></p>
        </div>
      </div>

      <p class="est__basis">
        These numbers are modeled from what's typical for your region and
        facility type: average cooling load, local weather, and peak-demand
        charges. The pilot measures what an average can't, your equipment's age
        and type, and how heavily your property is used.
      </p>

      <div class="est__detail">
        <div class="est__math">
          <h3 class="est__math-title">Applied to your property</h3>
          <ol class="est__steps" id="est-steps">
            <li><span class="op">Harmonization, 8% of spend</span><span class="num" id="est-harmo"></span></li>
            <li><span class="op">Cooling optimization, 15–55% of the cooling pool</span><span class="num" id="est-cool"></span></li>
            <li id="est-heat-row"><span class="op" id="est-heat-op">Heating bracket</span><span class="num" id="est-heat"></span></li>
            <li><span class="op">Demand reduction</span><span class="num" id="est-dem"></span></li>
            <li><span class="op">Outdoor lighting</span><span class="num" id="est-lit"></span></li>
            <li id="est-nego-row"><span class="op">Rate negotiation, deregulated market</span><span class="num" id="est-nego"></span></li>
          </ol>
        </div>
        <table class="est__table" id="est-inputs-table">
          <tbody>
            <tr><th scope="row">Electricity spend</th><td><span class="est__tv" id="est-t-spend"></span><span class="est__tn" id="est-t-spend-yr"></span></td></tr>
            <tr><th scope="row">HVAC share of bill</th><td><span class="est__tv" id="est-t-hvac"></span></td></tr>
            <tr><th scope="row">Cooling share of HVAC</th><td><span class="est__tv" id="est-t-cool"></span><span class="est__tn" id="est-t-state"></span></td></tr>
            <tr><th scope="row">Heating baseline</th><td><span class="est__tv" id="est-t-heat"></span></td></tr>
            <tr><th scope="row">Portfolio</th><td><span class="est__tv" id="est-t-count"></span></td></tr>
            <tr><th scope="row">Rate trajectory</th><td><span class="est__tv" id="est-t-rate"></span><span class="est__tn">documented escalation</span></td></tr>
          </tbody>
        </table>
      </div>

      <div class="est__facts">
        <div class="est__fact">
          <h3 class="est__fact-title">Two more loads we haven't shown</h3>
          <p class="est__fact-body">
            Beyond the elevator motors, per-room PTACs, and the pool and
            laundry drives from the scene above, the same distortion is
            working on your <strong>kitchen refrigeration</strong> and
            <strong>common-area lighting</strong>. The bill is the floor;
            <a href="#proof">the equipment is the other half of the story</a>.
          </p>
        </div>
      </div>

      <div class="est__cta">
        <p class="est__cta-line">
          That number is a model. The pilot replaces it with a measurement, at
          your meter, before you commit a dollar.
        </p>
        <CtaPair />
        <p class="est__disclaimer">
          Directional estimate using the conservative floor rates from the
          published model, applied to your electricity spend. Not a quote.
          <a href="#disclaimers">See full disclaimers.</a>
        </p>
      </div>
    </div>
  </div>
</section>

<script is:inline>
  (() => {
    const flow = document.getElementById("est-flow");
    if (!flow) return;
    const reduce = matchMedia("(prefers-reduced-motion: reduce)").matches;
    const $ = (id) => document.getElementById(id);
    const fmt = (n) => "$" + Math.round(n).toLocaleString("en-US");
    const fr = (a, b) => fmt(a) + " – " + fmt(b);

    const stateEl = $("est-state");
    const results = $("est-results");

    // fade the "tap to begin" cue the moment the user engages any input
    flow.addEventListener("change", () => flow.classList.add("is-engaged"), { once: true });

    // reveal a locked step once the prior one is answered
    const reveal = (el) => {
      if (!el || !el.hidden) return;
      el.hidden = false;
      el.setAttribute("aria-hidden", "false");
      requestAnimationFrame(() => el.classList.add("is-in"));
    };

    // compact dollars for the big range boxes (portfolio + projections)
    const fmtC = (n) => n >= 1e6 ? "$" + (n / 1e6).toFixed(2).replace(/\.?0+$/, "") + "M"
      : n >= 1e3 ? "$" + Math.round(n / 1e3) + "K" : "$" + Math.round(n);
    const frC = (a, b) => fmtC(a) + " – " + fmtC(b);

    // Section 179D square-footage slider; range tiers match the original calculator
    const fmtSqft = (n) => n.toLocaleString("en-US") + " sq ft";
    let sqftRng = { min: 0, max: 0 };
    function sqftRange(est) {
      if (est < 10000) return { min: Math.round(est * 0.5), max: Math.round(est * 2.0) };
      if (est < 50000) return { min: Math.round(est * 0.6), max: Math.round(est * 1.6) };
      if (est < 200000) return { min: Math.round(est * 0.7), max: Math.round(est * 1.4) };
      return { min: Math.round(est * 0.8), max: Math.round(est * 1.25) };
    }
    function sqftFromSlider(v, min, max) {
      const raw = min + (v / 100) * (max - min);
      const snap = raw < 10000 ? 500 : 1000;
      return Math.round(raw / snap) * snap;
    }
    function updateDed() {
      const sl = $("est-sqft-slider");
      const v = sqftFromSlider(Number(sl.value), sqftRng.min, sqftRng.max);
      $("est-sqft-cur").textContent = fmtSqft(v);
      $("est-sqft-min").textContent = fmtSqft(sqftRng.min);
      $("est-sqft-max").textContent = fmtSqft(sqftRng.max);
      sl.style.setProperty("--pct", sl.value + "%");
      const d = Math.round(v * 5.94), t = Math.round(d * 0.21);
      $("est-ded").textContent = "up to " + fmt(d);
      $("est-ded-tax").textContent = "≈ " + fmt(t) + " in tax at the 21% federal rate";
    }
    function initSqft(est) {
      sqftRng = sqftRange(est);
      const sl = $("est-sqft-slider");
      sl.value = 50;
      sl.oninput = updateDed;
      updateDed();
    }

    let hasComputed = false;
    let lastS = null;
    // recompute whenever all required inputs are present (any of the 5 changing)
    function recompute() {
      const narrow = flow.querySelector('input[name="est-narrow"]:checked');
      const cIn = flow.querySelector('input[name="est-count"]:checked');
      if (narrow && cIn && stateEl.value) compute();
    }

    // Step 1: a broad band swaps in its dial-in chips. On the first pass it just
    // reveals the dial-in; once results exist it keeps them live by defaulting to
    // the band's middle dial-in and recomputing (so results never vanish).
    flow.querySelectorAll('input[name="est-band"]').forEach((r) => {
      r.addEventListener("change", () => {
        flow.querySelectorAll('input[name="est-narrow"]').forEach((n) => (n.checked = false));
        flow.querySelectorAll(".est__narrow-group").forEach((g) => {
          g.hidden = g.getAttribute("data-band") !== r.value;
        });
        reveal($("est-step-narrow"));
        if (hasComputed) {
          const shown = flow.querySelector(".est__narrow-group:not([hidden])");
          const opts = shown ? [...shown.querySelectorAll('input[name="est-narrow"]')] : [];
          if (opts.length) { opts[Math.floor(opts.length / 2)].checked = true; recompute(); }
        }
      });
    });
    // later steps: reveal the next step AND recompute live on any change
    flow.querySelectorAll('input[name="est-narrow"]').forEach((n) => {
      n.addEventListener("change", () => { reveal($("est-step-count")); recompute(); });
    });
    flow.querySelectorAll('input[name="est-count"]').forEach((c) => {
      c.addEventListener("change", () => { reveal($("est-step-state")); recompute(); });
    });
    // clarifier box under the state picker: utility coverage cap for that state
    const coverEl = $("est-cover");
    function updateCover() {
      const opt = stateEl.options[stateEl.selectedIndex];
      if (!coverEl || !opt || !stateEl.value) { if (coverEl) coverEl.hidden = true; return; }
      const pct = Number(opt.getAttribute("data-cover")) || 50;
      coverEl.innerHTML =
        "Your <strong>" + opt.value + "</strong> utility company may cover up to " +
        "<strong>" + pct + "%</strong> of your project costs." +
        '<sup class="disc-ref"><a href="#disc-utility" aria-label="See disclaimer 4, utility and incentive programs">4</a></sup>';
      coverEl.hidden = false;
    }
    stateEl.addEventListener("change", () => { updateCover(); recompute(); });

    function compute() {
      const narrow = flow.querySelector('input[name="est-narrow"]:checked');
      const cIn = flow.querySelector('input[name="est-count"]:checked');
      if (!narrow || !cIn || !stateEl.value) return;

      const monthly = Number(narrow.value);
      const S = monthly * 12; // the model works on annual spend
      const opt = stateEl.options[stateEl.selectedIndex];
      const cool = Number(opt.getAttribute("data-cool")) / 100;
      const rate = Number(opt.getAttribute("data-rate"));
      const range = opt.getAttribute("data-range");
      const dereg = opt.getAttribute("data-dereg") === "1";
      const [lo, hi] = cIn.value.split("-").map(Number);
      const short = cIn.getAttribute("data-short");

      // streams, matched to the original calculator's hotel profile
      const harmo = 0.08 * S;             // harmonization floor, hotel 8%
      const H = 0.45 * S;                 // HVAC share of bill, hotel 45%
      const C = H * cool;                 // cooling pool = HVAC x state cooling split
      const coolF = 0.15 * C, coolC = 0.55 * C;
      const dem = 0.05 * 0.40 * S;        // demand reduction 5% x demand share 40%
      const litF = 0.04 * S, litC = 0.09 * S; // outdoor lighting, hotel 4-9%, off-grid x1.0
      const negoF = dereg ? 0.025 * S : 0, negoC = dereg ? 0.06 * S : 0;
      // Heating (heat-pump replacement) is left unmodeled by default, exactly
      // as the original: it is an upside, never part of the conservative floor.
      const floor = harmo + coolF + dem + litF + negoF;
      const ceil = harmo + coolC + dem + litC + negoC;

      // report header
      const today = new Date().toLocaleDateString("en-US", { year: "numeric", month: "long", day: "numeric" });
      $("est-report-meta").textContent =
        "Prepared for a " + short.replace("1 property", "single-property") +
        " operator in " + opt.value + " · " + today;

      // inputs panel
      $("est-t-spend").textContent = fmt(monthly) + " / mo";
      $("est-t-spend-yr").textContent = "≈ " + fmt(S) + " / yr";
      $("est-t-hvac").textContent = "45%";
      $("est-t-cool").textContent = Math.round(cool * 100) + "%";
      $("est-t-state").textContent = opt.value;
      $("est-t-heat").textContent = "not modeled";
      $("est-t-count").textContent = short;
      $("est-t-rate").textContent = range === "volatile" ? "volatile (2.5% floor)" : range + " / yr";

      // math steps
      $("est-harmo").textContent = fmt(harmo);
      $("est-cool").textContent = fr(coolF, coolC);
      $("est-heat-row").style.display = "none"; // heating left unmodeled (upside only)
      $("est-dem").textContent = fmt(dem);
      $("est-lit").textContent = fr(litF, litC);
      const negoRow = $("est-nego-row");
      negoRow.style.display = dereg ? "" : "none";
      if (dereg) $("est-nego").textContent = fr(negoF, negoC);
      $("est-range").textContent =
        "That's " + Math.round((floor / S) * 100) + "% to " +
        Math.round((ceil / S) * 100) +
        "% of your annual bill, per property, before incentives.";

      // portfolio header above the accumulation; the per-year figure is
      // omitted on purpose, the 5- and 10-year boxes carry the portfolio range
      $("est-portfolio-label").textContent =
        hi > 1 ? "Across " + short + " at similar spend" : "Per property, at this spend";

      // escalation applied to savings: annuity factor on the hero range
      const heroFloor = hi > 1 ? floor * lo : floor;
      const heroCeil = hi > 1 ? ceil * hi : ceil;
      const ef = (y) => (Math.pow(1 + rate, y) - 1) / rate;
      $("est-proj5").textContent = frC(heroFloor * ef(5), heroCeil * ef(5));
      $("est-proj10").textContent = frC(heroFloor * ef(10), heroCeil * ef(10));
      $("est-proj-note").textContent =
        "Commercial rates in " + opt.value + " have been rising " +
        (range === "volatile" ? "on a volatile trajectory (we project a conservative 2.5% floor)" : range + " a year") +
        "; these are the savings that compound away while you wait.";

      // Section 179D: re-estimate sqft only when spend changes, so a manual
      // slider drag survives a state or portfolio edit
      const raw = S / 3.5;
      const estSqft = raw >= 10000 ? Math.round(raw / 1000) * 1000 : raw >= 2000 ? Math.round(raw / 500) * 500 : Math.round(raw / 100) * 100;
      if (S !== lastS) { lastS = S; initSqft(estSqft); }
      reveal($("est-step-sqft"));

      // savings gauge: a mint band spans the floor->ceiling range, with a tick
      // at each end; full scale = 50% of the bill
      $("est-newbill").textContent = fr(floor, ceil);
      const MAXPCT = 0.5;
      const fF = Math.max(0, Math.min(1, (floor / S) / MAXPCT));
      const fC = Math.max(0, Math.min(1, (ceil / S) / MAXPCT));
      const rotDeg = (f) => (f - 0.5) * 180;
      const arcPt = (f) => { const th = Math.PI * (1 - f); return [100 + 82 * Math.cos(th), 104 - 82 * Math.sin(th)]; };
      const tickLo = $("est-tick-lo"), tickHi = $("est-tick-hi"), band = $("est-band");
      const [bx1, by1] = arcPt(fF), [bx2, by2] = arcPt(fC);
      band.setAttribute("d", "M" + bx1.toFixed(1) + " " + by1.toFixed(1) + " A82 82 0 0 1 " + bx2.toFixed(1) + " " + by2.toFixed(1));
      results.hidden = false;
      const placeTicks = () => {
        tickLo.style.transform = "rotate(" + rotDeg(fF) + "deg)";
        tickHi.style.transform = "rotate(" + rotDeg(fC) + "deg)";
      };
      const drawBand = (dur) => {
        const len = band.getTotalLength ? band.getTotalLength() : 0;
        if (!len) return;
        band.style.strokeDasharray = len;
        if (dur) {
          band.style.transition = "none";
          band.style.strokeDashoffset = len;
          requestAnimationFrame(() => {
            band.style.transition = "stroke-dashoffset " + dur + "ms cubic-bezier(0.25,1,0.5,1)";
            band.style.strokeDashoffset = 0;
          });
        } else {
          band.style.transition = "none";
          band.style.strokeDashoffset = 0;
        }
      };
      if (!hasComputed && !reduce) {
        // first run: ticks sweep in from the left, band draws across the range
        tickLo.style.transition = tickHi.style.transition = "none";
        tickLo.style.transform = tickHi.style.transform = "rotate(-90deg)";
        requestAnimationFrame(() => {
          tickLo.style.transition = tickHi.style.transition = "transform 1.1s cubic-bezier(0.25,1,0.5,1)";
          placeTicks();
        });
        drawBand(1100);
      } else {
        tickLo.style.transition = tickHi.style.transition = reduce ? "none" : "transform 0.5s cubic-bezier(0.25,1,0.5,1)";
        placeTicks();
        drawBand(0);
      }
      // first result lands: confirm the "reading captured" beat, lock the
      // headline number, and scroll the report into view.
      if (!hasComputed) {
        const cap = $("est-captured"); if (cap) cap.classList.add("is-on");
        const nb = $("est-newbill");
        if (nb) { nb.classList.remove("is-captured"); void nb.offsetWidth; nb.classList.add("is-captured"); }
        results.scrollIntoView({ behavior: reduce ? "auto" : "smooth", block: "start" });
      }
      hasComputed = true;
    }
  })();
</script>

