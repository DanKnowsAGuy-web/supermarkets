---
// BRUTAL-EDIT VARIANT of HvacShelf: a static, scannable spec list. Three
// columns per row (icon+title / descriptor / figures), animated icons, the
// figures kept in their own column so descriptors can never collide with them.
const rows = [
  {
    key: "solar", word: "Solar-thermal",
    desc: "The sun preheats the refrigerant. Thermal takes a fraction of the size and cost of solar panels.",
    figs: [{ pre: "up to", value: "30–40%", suf: "energy savings" }],
  },
  {
    key: "retrofit", word: "Compressor retrofit",
    desc: "Instead of buying a whole new system, make your existing compressor run like an intelligent one.",
    figs: [{ pre: "up to", value: "15–30%", suf: "energy savings" }],
  },
  {
    key: "roof", word: "Cool Roof Shield",
    desc: "Spray-on coatings or thermal membranes keep the heat off the building.",
    figs: [
      { value: "10–20°F", suf: "cooler roof" },
      { pre: "up to", value: "10–25%", suf: "energy savings" },
    ],
  },
  {
    key: "seal", word: "Permaseal",
    desc: "A one-time treatment. The older the unit, the more efficiency it brings back.",
    figs: [{ pre: "up to", value: "10–36%", suf: "energy savings" }],
  },
];
---

<section class="section hvl" id="hvac" aria-labelledby="hvl-title">
  <div class="container">
    <div class="hvl__head reveal">
      <p class="eyebrow">Heating and cooling</p>
      <h2 class="hvl__title" id="hvl-title">Your biggest burden is almost half your energy bill.</h2>
      <p class="hvl__lede lede">
        We carry more than 20 HVAC solutions so you can match the right fix for
        your building instead of forcing a vendor solution to work. A few of
        the most popular:
      </p>
    </div>

    <div class="hvl__hero reveal">
      <span class="hvl__hero-ribbon">The standard</span>
      <div class="hvl__hero-main">
        <span class="hvl__ico hvl__hero-ico" aria-hidden="true">
          <svg viewBox="0 0 48 48" fill="none">
            <rect class="hvl__s" x="7" y="17" width="26" height="18" rx="2" />
            <path class="hvl__s" d="M12 17 v18 M18 17 v18 M24 17 v18" opacity="0.55" />
            <g class="hvl__spark">
              <path class="hvl__s" d="M39 9 v9 M34.5 13.5 h9 M35.5 10 l7 7 M42.5 10 l-7 7" />
            </g>
          </svg>
        </span>
        <div class="hvl__hero-copy">
          <h3 class="hvl__hero-title">One unit, both loads.</h3>
          <p class="hvl__hero-desc">
            When a unit is finally done, replace it with the gold standard: one
            machine that heats and cools your building at best-in-class efficiency.
          </p>
          <span class="hvl__badge">IEER 31 · COP 6</span>
        </div>
      </div>
      <div class="hvl__hero-figs">
        <div class="hvl__hero-fig hvl__fig--cool">
          <span class="hvl__fig-pre">up to</span>
          <span class="hvl__fig-val">55%</span>
          <span class="hvl__fig-suf">cooling energy savings</span>
        </div>
        <span class="hvl__hero-div" aria-hidden="true"></span>
        <div class="hvl__hero-fig hvl__fig--warm">
          <span class="hvl__fig-pre">up to</span>
          <span class="hvl__fig-val">60%</span>
          <span class="hvl__fig-suf">heating energy savings</span>
        </div>
      </div>
    </div>

    <p class="hvl__sublabel reveal">Or zero in on one gain:</p>

    <ol class="hvl__list">
      {rows.map((r, i) => (
        <li class="hvl__row reveal" style={`--i: ${i}`}>
          <div class="hvl__id">
            <span class="hvl__ico" aria-hidden="true">
              {r.key === "roof" && (
                <svg viewBox="0 0 48 48" fill="none">
                  <circle class="hvl__s hvl__sun" cx="35" cy="12" r="4.5" />
                  <path class="hvl__s" d="M8 31 L24 19 L40 31" />
                  <path class="hvl__s" d="M6 39 H42" />
                  <path class="hvl__s hvl__heat" d="M16 14 q3 -3 0 -6 M24 12 q3 -3 0 -6" opacity="0.7" />
                </svg>
              )}
              {r.key === "seal" && (
                <svg viewBox="0 0 48 48" fill="none">
                  <path class="hvl__s" d="M8 16 H40 M8 24 H40 M8 32 H40" />
                  <g class="hvl__spark">
                    <path class="hvl__s" d="M34 6 v8 M30 10 h8 M31 7 l6 6 M37 7 l-6 6" />
                  </g>
                </svg>
              )}
              {r.key === "retrofit" && (
                <svg viewBox="0 0 48 48" fill="none">
                  <circle class="hvl__s" cx="24" cy="24" r="13" />
                  <g class="hvl__rot">
                    <circle class="hvl__s" cx="24" cy="24" r="5" />
                    <path class="hvl__s" d="M24 11 v-4 M24 37 v4 M11 24 h-4 M37 24 h4" />
                  </g>
                </svg>
              )}
              {r.key === "solar" && (
                <svg viewBox="0 0 48 48" fill="none">
                  <circle class="hvl__s hvl__sun" cx="17" cy="15" r="5" />
                  <path class="hvl__s hvl__sun" d="M17 6 v-2 M17 26 v2 M8 15 h-2 M28 15 h2 M10 8 l-1.5 -1.5 M24 8 l1.5 -1.5" />
                  <rect class="hvl__s" x="22" y="29" width="18" height="10" rx="1" />
                  <path class="hvl__s" d="M28 29 v10 M34 29 v10" opacity="0.55" />
                </svg>
              )}
              {r.key === "replace" && (
                <svg viewBox="0 0 48 48" fill="none">
                  <rect class="hvl__s" x="7" y="17" width="26" height="18" rx="2" />
                  <path class="hvl__s" d="M12 17 v18 M18 17 v18 M24 17 v18" opacity="0.55" />
                  <g class="hvl__spark">
                    <path class="hvl__s" d="M39 9 v9 M34.5 13.5 h9 M35.5 10 l7 7 M42.5 10 l-7 7" />
                  </g>
                </svg>
              )}
            </span>
            <span class="hvl__word">{r.word}</span>
          </div>

          <p class="hvl__desc">{r.desc}</p>

          <div class="hvl__figs">
            {r.figs.map((f) => (
              <span class={`hvl__fig${f.tone ? " hvl__fig--" + f.tone : ""}`}>
                {f.pre && <span class="hvl__fig-pre">{f.pre} </span>}
                <span class="hvl__fig-val">{f.value}</span>
                {f.suf && <span class="hvl__fig-suf"> {f.suf}</span>}
              </span>
            ))}
            {r.badge && <span class="hvl__badge">{r.badge}</span>}
          </div>
        </li>
      ))}
    </ol>
  </div>
</section>

<style>
  .hvl { border-top: 1px solid var(--line); }
  .hvl__head { max-width: 54rem; }
  .hvl__title { font-size: var(--step-3); max-width: 22ch; }
  .hvl__lede { margin-top: var(--space-m); max-width: 60ch; }

  /* featured unit: pulled out of the list, accented, dual heat+cool split */
  .hvl__hero {
    position: relative;
    margin: var(--space-xl) 0 var(--space-l);
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    gap: clamp(1.5rem, 4vw, 3rem);
    align-items: center;
    padding: clamp(1.6rem, 3.5vw, 2.4rem);
    border: 1px solid var(--gold);
    border-radius: var(--radius);
    background:
      radial-gradient(130% 150% at 100% 0%, var(--gold-soft), transparent 58%),
      var(--surface);
    box-shadow: var(--shadow-lift, 0 18px 44px -26px rgba(0, 0, 0, 0.7));
  }
  .hvl__hero-ribbon {
    position: absolute; top: 0; left: clamp(1.6rem, 3.5vw, 2.4rem);
    transform: translateY(-50%);
    font-family: var(--font-mono); font-size: 0.6rem; letter-spacing: 0.16em;
    text-transform: uppercase; color: var(--bg); background: var(--gold-text);
    padding: 0.32em 0.7em; border-radius: 999px;
  }
  .hvl__hero-main { display: flex; gap: clamp(1rem, 2.5vw, 1.6rem); align-items: flex-start; }
  .hvl__hero-ico svg { width: 60px; height: 60px; }
  .hvl__hero-title { font-size: var(--step-2); color: var(--ink); letter-spacing: -0.01em; }
  .hvl__hero-desc { margin-top: 0.5rem; font-size: var(--step-0); line-height: 1.55; color: var(--body); max-width: 44ch; }
  .hvl__hero .hvl__badge { display: inline-block; margin-top: var(--space-s); }
  .hvl__hero-figs { display: flex; align-items: center; gap: clamp(1rem, 2.5vw, 1.8rem); }
  .hvl__hero-fig { display: grid; justify-items: center; text-align: center; font-family: var(--font-serif); line-height: 1.05; }
  .hvl__hero-fig .hvl__fig-val { font-size: clamp(2rem, 4vw, 3rem); letter-spacing: -0.02em; font-variant-numeric: tabular-nums; }
  .hvl__hero-div { width: 1px; height: 3.6rem; background: var(--line-strong); }

  .hvl__sublabel {
    font-family: var(--font-mono); font-size: 0.66rem; letter-spacing: 0.14em;
    text-transform: uppercase; color: var(--muted); margin-bottom: var(--space-xs);
  }

  .hvl__list { list-style: none; margin: 0; padding: 0; }
  .hvl__row {
    display: grid;
    grid-template-columns: 9rem minmax(0, 1fr) 12rem;
    align-items: center;
    column-gap: clamp(1.5rem, 4vw, 3rem);
    padding: clamp(1.5rem, 3.5vw, 2rem) 0;
    border-bottom: 1px solid var(--line);
  }
  .hvl__row:first-child { border-top: 1px solid var(--line); }

  /* column 1: icon over title, centered */
  .hvl__id { text-align: center; }
  .hvl__ico svg { width: 52px; height: 52px; margin: 0 auto; }
  .hvl__s {
    stroke: var(--gold-text); stroke-width: 1.6; fill: none;
    stroke-linecap: round; stroke-linejoin: round;
  }
  .hvl__word {
    display: block;
    margin-top: 0.45rem;
    font-size: var(--step-0);
    color: var(--ink);
    letter-spacing: -0.01em;
    line-height: 1.15;
  }

  /* column 2: descriptor */
  .hvl__desc {
    font-size: var(--step-0);
    line-height: 1.55;
    color: var(--body);
    max-width: 44ch;
  }

  /* column 3: figures, centered in their own column, isolated from the desc */
  .hvl__figs {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.25rem;
    text-align: center;
  }
  .hvl__fig {
    display: grid;
    justify-items: center;
    gap: 0.05rem;
    font-family: var(--font-serif);
    color: var(--gold-text);
    line-height: 1.05;
  }
  .hvl__fig-pre {
    font-family: var(--font-mono);
    font-size: 0.6rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--muted);
  }
  .hvl__fig-val {
    font-size: clamp(1.7rem, 3vw, 2.3rem);
    letter-spacing: -0.02em;
    font-variant-numeric: tabular-nums;
    white-space: nowrap;
  }
  .hvl__fig-suf {
    font-family: var(--font-mono);
    font-size: 0.62rem;
    letter-spacing: 0.04em;
    color: var(--muted);
  }
  .hvl__fig--cool .hvl__fig-val { color: var(--h-teal, #6fb2cf); }
  .hvl__fig--warm .hvl__fig-val { color: var(--cost, #d8a55a); }

  .hvl__badge {
    margin-top: 0.45rem;
    font-family: var(--font-mono);
    font-size: 0.66rem;
    letter-spacing: 0.06em;
    color: var(--gold-text);
    border: 1px solid var(--gold);
    border-radius: 8px;
    padding: 0.4em 0.7em;
    background: var(--gold-soft);
    white-space: nowrap;
  }

  /* motion */
  @media (prefers-reduced-motion: no-preference) {
    .hvl__rot { transform-box: fill-box; transform-origin: center; animation: hvlSpin 3.6s linear infinite; }
    @keyframes hvlSpin { to { transform: rotate(360deg); } }
    .hvl__sun { transform-box: fill-box; transform-origin: center; animation: hvlSun 2.6s ease-in-out infinite; }
    @keyframes hvlSun { 0%, 100% { opacity: 0.55; transform: scale(0.88); } 50% { opacity: 1; transform: scale(1.12); } }
    .hvl__spark { transform-box: fill-box; transform-origin: center; animation: hvlTwinkle 2.2s ease-in-out infinite; }
    @keyframes hvlTwinkle { 0%, 100% { opacity: 0.35; transform: scale(0.8) rotate(0deg); } 50% { opacity: 1; transform: scale(1.15) rotate(15deg); } }
    .hvl__heat { transform-box: fill-box; transform-origin: center bottom; animation: hvlHeat 2s ease-in-out infinite; }
    @keyframes hvlHeat { 0%, 100% { opacity: 0.25; transform: translateY(2px); } 50% { opacity: 0.85; transform: translateY(-2px); } }
  }

  @media (max-width: 46rem) {
    .hvl__hero { grid-template-columns: 1fr; gap: var(--space-l); }
    .hvl__hero-figs { justify-content: flex-start; }
    .hvl__row {
      grid-template-columns: 56px 1fr;
      grid-template-areas: "ico desc" "ico figs";
      column-gap: var(--space-m);
      row-gap: 0.5rem;
      align-items: start;
    }
    .hvl__id { grid-area: ico; }
    .hvl__ico svg { width: 40px; height: 40px; }
    .hvl__word { font-size: var(--step--1); }
    .hvl__desc { grid-area: desc; }
    .hvl__figs { grid-area: figs; align-items: flex-start; text-align: left; }
  }
</style>
