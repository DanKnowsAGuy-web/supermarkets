---
// HYBRID "Mix" theme, DARK-DOMINANT variant (preview at /brutal4d/).
// Inverts brutal4: graphite/slate is the primary surface for most of the page,
// with paper-white reserved for a couple of bright "evidence" inserts (.paper).
// Signal teal + Quiet red accents throughout. Same components, token override.
// VARIANT: hotel cutaway / section hero (concept A) at /herocut/.
import Base from "../layouts/Base.astro";
import Header from "../components/Header.astro";
import Hero from "../components/HeroCutaway.astro";
import OfferLean from "../components/OfferLean.astro";
import Plan from "../components/Plan.astro";
import ProblemLean from "../components/ProblemLean.astro";
import Engineer from "../components/Engineer.astro";
import ActFourLean from "../components/ActFourLean.astro";
import Harmonizer from "../components/Harmonizer.astro";
import Proof from "../components/Proof.astro";
import HvacLean from "../components/HvacLean.astro";
import FloorStat from "../components/FloorStat.astro";
import Estimator from "../components/Estimator.astro";
import Success from "../components/Success.astro";
import FinalCta from "../components/FinalCta.astro";
import Footer from "../components/Footer.astro";
---

<Base>
  <div class="theme-dark">
    <div class="bp-ambient" data-parallax aria-hidden="true"></div>
    <Header />
    <main id="main">
      <Hero />
      <div class="paper"><OfferLean /></div>
      <Plan />
      <ProblemLean />
      <Engineer />
      <ActFourLean />
      <Harmonizer />
      <div class="paper"><Proof /></div>
      <HvacLean />
      <FloorStat />
      <Estimator />
      <Success />
      <FinalCta />
    </main>
    <Footer />
  </div>
</Base>

<style is:global>
  /* --- Slate graphite: the dominant surface ---------------------------- */
  .theme-dark {
    --bg: #141a1e; --bg-header: #0f1418; --hero-from: #1c2329; --hero-to: #141a1e;
    --surface: #1d242b; --surface-2: #252e36;
    --ink: #eef1ef; --body: #bac2c1; --muted: #8b9592;
    --gold: #1f8390; --gold-text: #46cfd6; --mint: #46cfd6; --cost: #c87a64;
    --h-red: #c87a64; --h-teal: #46cfd6;
    --line: rgba(220, 230, 230, 0.12); --line-strong: rgba(220, 230, 230, 0.2);
    --gold-soft: rgba(31, 131, 144, 0.12); --mint-soft: rgba(70, 207, 214, 0.13);
    /* dual-layer depth: inset top highlight (catches light) + soft drop */
    --shadow-lift: 0 1px 0 rgba(255, 255, 255, 0.06) inset, 0 22px 50px -24px rgba(0, 0, 0, 0.85);
    /* tilt-state shadow: deeper drop + a teal edge ring */
    --shadow-tilt: 0 1px 0 rgba(255, 255, 255, 0.08) inset, 0 36px 70px -28px rgba(0, 0, 0, 0.92),
      0 0 0 1px color-mix(in srgb, var(--gold) 32%, transparent);
    --font-serif: "Hanken Grotesk", system-ui, sans-serif;
    --font-sans: "Hanken Grotesk", system-ui, sans-serif;
    --font-mono: "Geist Mono", ui-monospace, monospace;
    background: #141a1e; color: #eef1ef;
  }

  /* (1) cards lift off the slate */
  .theme-dark :is(.offerl__box, .probl__panel, .step, .win__col, .eng__card,
    .eng__tile, .eng__photo, .est__measured, .hz__card, .case) {
    box-shadow: var(--shadow-lift);
  }
  /* living cards: 3D tilt toward the cursor (JS sets the transform), with a
     deeper drop + teal edge ring while engaged */
  .theme-dark :is(.case, .eng__card, .eng__tile, .probl__panel, .offerl__box,
    .win__col, .step, .est__measured) {
    transform-style: preserve-3d;
    transition: transform 0.5s var(--ease-out-quart), box-shadow 0.5s ease;
    will-change: transform;
  }
  .theme-dark .is-tilting {
    transition: transform 0.07s linear, box-shadow 0.25s ease;
    box-shadow: var(--shadow-tilt);
    z-index: 2;
  }

  /* (2)+(3) ambient teal/red light, parallaxed by the pointer. Screen-blended
     over the slate so it reads as atmosphere; faint enough to keep text crisp.
     Different blobs sit under different sections as you scroll. */
  .bp-ambient {
    position: fixed; inset: -8%; z-index: 0; pointer-events: none;
    background:
      radial-gradient(42% 34% at 14% 18%, color-mix(in srgb, var(--mint) 42%, transparent), transparent 68%),
      radial-gradient(48% 42% at 90% 52%, color-mix(in srgb, var(--gold) 38%, transparent), transparent 70%),
      radial-gradient(44% 36% at 52% 98%, color-mix(in srgb, var(--cost) 26%, transparent), transparent 68%);
    mix-blend-mode: screen;
    opacity: 0.75;
    transform: translate3d(var(--px, 0), var(--py, 0), 0);
    transition: transform 0.7s var(--ease-out-quart);
    will-change: transform;
  }
  @media (prefers-reduced-motion: reduce) {
    .bp-ambient { transition: none; transform: none; }
  }
  /* keep the screen-blend off the light paper inserts (it would blow them out):
     lift them into their own layer above the fixed ambient */
  .theme-dark .paper { position: relative; z-index: 1; }

  /* (4) magnetic CTA: the button drifts toward the cursor and lights a soft
     teal sheen where the pointer sits */
  .theme-dark .btn {
    position: relative; overflow: hidden;
    transform: translate(var(--bx, 0px), var(--by, 0px));
    transition: transform 0.3s var(--ease-out-quart), background-color 0.3s ease;
  }
  .theme-dark .btn:hover { transform: translate(var(--bx, 0px), calc(var(--by, 0px) - 2px)); }
  .theme-dark .btn::after {
    content: ""; position: absolute; inset: 0; pointer-events: none;
    background: radial-gradient(90px circle at var(--mx, 50%) var(--my, 50%),
      color-mix(in srgb, var(--gold) 55%, transparent), transparent 60%);
    mix-blend-mode: soft-light;
    opacity: 0; transition: opacity 0.35s ease;
  }
  .theme-dark .btn:hover::after { opacity: 1; }
  @media (prefers-reduced-motion: reduce) {
    .theme-dark .btn { transform: none; }
    .theme-dark .btn:hover { transform: translateY(-2px); }
  }
  /* button = ink fill, bg text (resolves correctly on dark and on paper) */
  .theme-dark .btn { background: var(--ink); color: var(--bg); }
  .theme-dark .btn:hover { background: #ffffff; box-shadow: none; }
  .theme-dark .afl__fig { color: var(--cost) !important; }

  /* --- Inserts: muted, charcoal-leaning off-white (dimmed to ease glare) - */
  .theme-dark .paper {
    --bg: #d4d8d2; --surface: #dde0da; --surface-2: #cbcfc9;
    --ink: #1a1d1a; --body: #3c413b; --muted: #5d625b;
    --gold: #0d6f79; --gold-text: #0d6f79; --mint: #0d6f79; --cost: #8f4030;
    --h-red: #8f4030; --h-teal: #0d6f79;
    --line: rgba(20, 25, 20, 0.14); --line-strong: rgba(20, 25, 20, 0.22);
    --gold-soft: rgba(13, 111, 121, 0.09); --mint-soft: rgba(13, 111, 121, 0.12);
    --shadow-lift: 0 1px 0 rgba(255, 255, 255, 0.6) inset, 0 16px 40px -28px rgba(0, 0, 0, 0.22);
    background: #d4d8d2; color: #1a1d1a;
  }
  .theme-dark .paper .btn:hover { background: #2f352e; }
</style>
